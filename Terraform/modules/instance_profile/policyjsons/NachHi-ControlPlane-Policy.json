{
	"Version": "2012-10-17",
	"Statement": [
		{
			"Effect": "Allow",
			"Action": [
				"ssm:PutParameter",
				"ssm:GetParameter"
			],
			"Resource": [
				"arn:aws:ssm:us-east-1:*:parameter/k8s/NachHi/Join/ControlPlane",
				"arn:aws:ssm:us-east-1:*:parameter/k8s/NachHi/Join/Worker"
			]
		},
		{
			"Effect": "Allow",
			"Action": [
				"kms:Decrypt",
				"kms:GenerateDataKey"
			],
			"Resource": "arn:aws:kms:us-east-1:*:alias/aws/ssm"
		},
		{
			"Effect": "Allow",
			"Action": [
				"ecr:GetAuthorizationToken"
			],
			"Resource": "*"
		},
		{
			"Effect": "Allow",
			"Action": [
				"ecr:BatchGetImage",
				"ecr:GetDownloadUrlForLayer",
				"ecr:BatchCheckLayerAvailability"
			],
			"Resource": "arn:aws:ecr:us-east-1:*:repository/StatusPage"
		}
	]
}